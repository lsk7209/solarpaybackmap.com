NEXT_PUBLIC_SITE_URL=https://example.com

# NLR PVWatts V8 + UtilityRates V3 API (developer.nlr.gov)
# Required for Phase 2 county precompute scripts. Not used at runtime.
# Register at https://developer.nlr.gov/signup/. 1,000 req/hr/key.
NLR_API_BASE=https://developer.nlr.gov
NLR_API_KEY=DEMO_KEY
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# Google AdSense client ID. Keep unset until approved; placeholders are ignored.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-0000000000000000
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Future Turso integration for production county/state precompute data.
TURSO_DATABASE_URL=libsql://example.turso.io
TURSO_AUTH_TOKEN=

# Local-only GSC sitemap submission. Do not commit real secret files.
GSC_SITE_URL=https://example.com/
GSC_SITEMAP_URL=https://example.com/sitemap.xml
GSC_TOKEN_FILE=D:\env\gsc_token.json
GSC_CLIENT_SECRETS_FILE=D:\env\adsense_oauth_client.json
